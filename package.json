  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@epic-web/client-hints": "^1.3.9",
    "@epic-web/invariant": "^1.0.0",
    "@epic-web/totp": "^4.0.1",
    "@nichtsam/helmet": "^0.3.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tabler/icons-react": "^3.44.0",
    "@vanilla-extract/css": "^1.21.1",
    "isbot": "^5.2.0",
    "openimg": "^1.1.1",
    "posthog-js": "^1.399.1",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.2.0",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "spin-delay": "^2.0.1",
    "ts-pattern": "^5.9.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "8.2.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.10",
    "msw": "^2.15.0",
    "react-router-auto-routes": "^0.8.4",
    "storybook": "^10.5.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.10"
  },
  "name": "personal-app-template-sqlite-fly-io",
  "packageManager": "pnpm@11.11.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && react-router build",
    "build:secrets": "infisical run --env=dev --path=/web -- pnpm build",
    "check": "biome check --write .",
    "db:migrate": "prisma migrate dev --name",
    "db:migrate:prod": "prisma migrate deploy",
    "db:migrate:prod:secrets": "infisical run --env=prod --path=/web -- pnpm db:migrate:prod",
    "db:migrate:secrets": "infisical run --env=dev --path=/web -- pnpm db:migrate",
    "db:push": "prisma db push",
    "db:push:secrets": "infisical run --env=dev --path=/web -- pnpm db:push",
    "db:reset": "prisma migrate reset --force && prisma db push && pnpm db:seed",
    "db:reset:secrets": "infisical run --env=dev --path=/web -- pnpm db:reset",
    "db:seed": "prisma db seed",
    "db:seed:secrets": "infisical run --env=dev --path=/web -- pnpm db:seed",
    "db:studio": "prisma studio",
    "db:studio:secrets": "infisical run --env=dev --path=/web -- pnpm db:studio",
    "dev": "infisical run --env=dev --path=/web -- react-router dev",
    "dev:secrets": "pnpm dev",
    "lint": "biome ci .",
    "prepare": "lefthook install",
    "secrets:dev": "infisical run --env=dev --path=/web --",
    "secrets:prod": "infisical run --env=prod --path=/web --",
    "secrets:staging": "infisical run --env=staging --path=/web --",
    "start": "react-router-serve ./build/server/index.js",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "storybook:build": "STORYBOOK=true storybook build",
    "test": "vitest run",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:secrets": "infisical run --env=dev --path=/web -- pnpm test:e2e",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:secrets": "infisical run --env=dev --path=/web -- pnpm test",
    "test:watch": "vitest",
    "typecheck": "prisma generate && react-router typegen && tsc",
    "typecheck:secrets": "infisical run --env=dev --path=/web -- pnpm typecheck"
  },
  "type": "module"
}
